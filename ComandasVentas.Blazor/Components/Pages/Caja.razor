    private string NombreVendedorMesa(string nombreMesa)
    {
        var cuentaMesa = (CajaData?.CuentasMesasVista ?? []).FirstOrDefault(x => string.Equals(x.NombreMesa?.Trim(), nombreMesa?.Trim(), StringComparison.OrdinalIgnoreCase));
        return cuentaMesa is null ? string.Empty : NombreVendedorCorto(cuentaMesa.NombreVendedor);
    }

    private CuentaCajaData? ObtenerCuentaPorMesa(int idMesa)
    {
        var relacion = CajaData?.RelacionesVentaMesa.FirstOrDefault(x => x.IdMesa == idMesa);
        if (relacion is null)
        {
            return null;
        }

        return (CajaData?.CuentasMesasVista ?? []).FirstOrDefault(x => x.Id == relacion.IdVenta)
               ?? (CajaData?.Cuentas ?? []).FirstOrDefault(x => x.Id == relacion.IdVenta);
    }

    private bool PuedeGestionarMesa(CuentaCajaData? cuentaMesa)
    {
        if (SessionState.Vendedor?.CajaMovil == 1)
        {
            return true;
        }

        if (SessionState.DbConexion?.MeserosCompartidos == true)
        {
            return true;
        }

        if (cuentaMesa is null)
        {
            return true;
        }

        return cuentaMesa.IdVendedor == SessionState.Vendedor?.Id;
    }

    private decimal ObtenerCantidadProducto(int idPresentacion)
    {
        if (!ProductoCantidades.TryGetValue(idPresentacion, out var cantidad) || cantidad <= 0)
        {
            ProductoCantidades[idPresentacion] = 1m;
            return 1m;
        }

        return cantidad;
    }

    private void CambiarCantidadProducto(int idPresentacion, decimal delta)
    {
        var valor = ObtenerCantidadProducto(idPresentacion);
        ProductoCantidades[idPresentacion] = Math.Max(1m, valor + delta);
    }

    private void CambiarCantidadProductoInput(int idPresentacion, ChangeEventArgs e)
    {
        if (decimal.TryParse((Convert.ToString(e.Value) ?? "1").Replace(",", "."), NumberStyles.Any, CultureInfo.InvariantCulture, out var cantidad))
        {
            ProductoCantidades[idPresentacion] = Math.Max(1m, cantidad);
        }
    }

    private decimal ObtenerCantidadDetalle(int idDetalle)
    {
        if (!DetalleCantidades.TryGetValue(idDetalle, out var cantidad) || cantidad <= 0)
        {
            var valor = CajaData?.Detalles.FirstOrDefault(x => x.Id == idDetalle)?.Unidad ?? 1m;
            DetalleCantidades[idDetalle] = Math.Max(1m, valor);
            return DetalleCantidades[idDetalle];
        }

        return cantidad;
    }

    private void CambiarCantidadDetalle(int idDetalle, decimal delta)
    {
        var valor = ObtenerCantidadDetalle(idDetalle);
        DetalleCantidades[idDetalle] = Math.Max(1m, valor + delta);
    }

    private void CambiarCantidadDetalleInput(int idDetalle, ChangeEventArgs e)
    {
        if (decimal.TryParse((Convert.ToString(e.Value) ?? "1").Replace(",", "."), NumberStyles.Any, CultureInfo.InvariantCulture, out var cantidad))
        {
            DetalleCantidades[idDetalle] = Math.Max(1m, cantidad);
        }
    }

    private void SincronizarCantidadesDetalle()
    {
        DetalleCantidades.Clear();
        foreach (var detalle in CajaData?.Detalles ?? [])
        {
            DetalleCantidades[detalle.Id] = Math.Max(1m, detalle.Unidad);
        }
    }

    private void SetLoadingState(string kicker, string title, string copy)
    {
        LoadingKicker = kicker;
        LoadingTitle = title;
        LoadingCopy = copy;
        IsLoading = true;
    }

    private void MostrarMensaje(string mensaje, bool esError)
    {
        AlertModernoCts?.Cancel();
        AlertModernoCts?.Dispose();
        AlertModernoCts = new CancellationTokenSource();
        AlertModernoMensaje = mensaje;
        AlertModernoEsError = esError;
        ShowAlertModerno = true;
        _ = AutoCerrarAlertModernoAsync(AlertModernoCts.Token);
    }

    private void CerrarAlertModerno()
    {
        AlertModernoCts?.Cancel();
        AlertModernoCts?.Dispose();
        AlertModernoCts = null;
        ShowAlertModerno = false;
        AlertModernoMensaje = string.Empty;
        AlertModernoEsError = false;
    }

    private async Task AutoCerrarAlertModernoAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(AlertModernoEsError ? 1600 : 1100, cancellationToken);
            if (cancellationToken.IsCancellationRequested)
            {
                return;
            }

            await InvokeAsync(() =>
            {
                ShowAlertModerno = false;
                AlertModernoMensaje = string.Empty;
                AlertModernoEsError = false;
                StateHasChanged();
            });
        }
        catch (TaskCanceledException)
        {
        }
    }

    private static string NombreVendedorCorto(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return string.Empty;
        var partes = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (partes.Length < 2) return partes[0];
        var dos = $"{partes[0]} {partes[1]}";
        return dos.Length <= 18 ? dos : $"{partes[0]} {partes[1][0]}.";
    }

    private static string FormatearMoneda(decimal valor) => valor.ToString("C0", CultureInfo.GetCultureInfo("es-CO"));

    private void CerrarModalMesa()
    {
        if (IsMesaActionRunning)
        {
            return;
        }

        ShowMesaModal = false;
        MesaStatusModal = null;
        MesaStatusHasError = false;
    }

    private void AbrirModalCierreCaja()
    {
        CajaStatusHasError = false;
        CajaStatusMessage = null;
        ObservacionCierre = string.Empty;
        ShowCerrarCajaModal = true;
    }

    private void CancelarCierreCaja()
    {
        if (IsClosingCaja) return;
        ShowCerrarCajaModal = false;
        CajaStatusMessage = null;
        CajaStatusHasError = false;
    }

    private async Task ConfirmarCierreCajaAsync()
    {
        if (SessionState.BaseCaja is null)
        {
            CajaStatusHasError = true;
            CajaStatusMessage = "No se encontro una caja activa para cerrar.";
            return;
        }

        IsClosingCaja = true;
        CajaStatusHasError = false;
        CajaStatusMessage = "Cerrando caja...";
        var response = await LoginDataService.CerrarBaseCajaAsync(DbVisual, SessionState.BaseCaja, SessionState.Vendedor);
        IsClosingCaja = false;

        if (!response.Success)
        {
            CajaStatusHasError = true;
            CajaStatusMessage = response.Message;
            return;
        }

        SessionState.SetBaseCaja(response.BaseCaja);
        ShowCerrarCajaModal = false;
        SessionState.Clear();
        NavigationManager.NavigateTo($"/login?db={Uri.EscapeDataString(DbVisual)}", forceLoad: false);
    }

    private void CerrarSesion()
    {
        SessionState.Clear();
        NavigationManager.NavigateTo($"/login?db={Uri.EscapeDataString(DbVisual)}", forceLoad: false);
    }

