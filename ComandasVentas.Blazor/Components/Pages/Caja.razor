    private async Task RecargarCajaAsync(bool showLoader = true)
    {
        if (SessionState.Vendedor is null)
        {
            LoadError = "La sesion no tiene un vendedor activo.";
            IsLoading = false;
            return;
        }

        try
        {
            if (showLoader)
            {
                SetLoadingState("Sincronizando", "Actualizando caja", "Estamos consultando la informacion real desde SQL Server.");
            }
            LoadError = null;

            CajaData = await CajaDataService.LoadCajaAsync(DbVisual, SessionState.Vendedor, SessionState.DbConexion, SelectedCuentaId);
            SelectedCuentaId = CajaData.Cuentas.FirstOrDefault(x => x.Id == SelectedCuentaId)?.Id ?? CajaData.Cuentas.FirstOrDefault()?.Id ?? 0;

            var relacionMesaActiva = CajaData.RelacionesVentaMesa.FirstOrDefault(x => x.IdVenta == SelectedCuentaId);
            SelectedMesaId = relacionMesaActiva?.IdMesa ?? 0;

            if (relacionMesaActiva is not null)
            {
                var mesaActiva = CajaData.Mesas.FirstOrDefault(x => x.Id == relacionMesaActiva.IdMesa);
                SelectedZonaId = mesaActiva?.IdZona ?? CajaData.Zonas.FirstOrDefault(x => x.Id == SelectedZonaId)?.Id ?? CajaData.Zonas.FirstOrDefault()?.Id ?? 0;
            }
            else
            {
                SelectedZonaId = CajaData.Zonas.FirstOrDefault(x => x.Id == SelectedZonaId)?.Id ?? CajaData.Zonas.FirstOrDefault()?.Id ?? 0;
            }

            SelectedCategoriaId = CajaData.Categorias.FirstOrDefault(x => x.Id == SelectedCategoriaId)?.Id ?? CajaData.Categorias.FirstOrDefault()?.Id ?? 0;
            if (SelectedCuentaClienteId > 0 && !CajaData.CuentasCliente.Any(x => x.Id == SelectedCuentaClienteId))
            {
                SelectedCuentaClienteId = 0;
            }

            SincronizarCantidadesDetalle();
        }
        catch (Exception ex)
        {
            LoadError = $"No fue posible cargar la caja con informacion real. {ex.Message}";
        }
        finally
        {
            if (showLoader)
            {
                IsLoading = false;
            }
        }
    }

