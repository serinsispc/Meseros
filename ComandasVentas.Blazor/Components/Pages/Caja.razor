@page "/caja"
@using System.Globalization
@using ComandasVentas.Blazor.Models.Caja
@using ComandasVentas.Blazor.Services.Auth
@using ComandasVentas.Blazor.Services.Caja
@inject NavigationManager NavigationManager
@inject AppSessionState SessionState
@inject LoginDataService LoginDataService
@inject CajaDataService CajaDataService

<PageTitle>Caja</PageTitle>

<main class="container-fluid app-shell caja-blazor-page">
    @if (IsLoading)
    {
        <div class="caja-loading-overlay" role="status" aria-live="polite">
            <div class="caja-loading-card">
                <div class="caja-loading-icon-wrap">
                    <div class="caja-loading-spinner"></div>
                    <div class="caja-loading-icon">
                        <i class="bi bi-database-check"></i>
                    </div>
                </div>
                <div class="caja-loading-kicker">@LoadingKicker</div>
                <div class="caja-loading-title">@LoadingTitle</div>
                <div class="caja-loading-copy">@LoadingCopy</div>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <div class="caja-status-banner is-error m-3" role="alert">
            <div class="caja-status-icon">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div class="caja-status-copy">
                <div class="caja-status-title">No fue posible cargar la caja</div>
                <div class="caja-status-text">@LoadError</div>
            </div>
        </div>
    }

    <div class="row g-1 h-100">
        <section class="col-12 col-xl-8 d-flex flex-column">
            <div class="panel panel-alto-auto b-orange mb-1 py-2 border-0">
                <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between gap-2">
                    <div class="fw-bold text-dark ps-2">
                        <span class="fw-semibold">@NombreVendedor</span>
                        <span class="ms-2 text-muted small">DB: @DbVisual</span>
                    </div>

                    <div class="acciones-top d-flex flex-wrap gap-2">
                        <button type="button" class="btn-top btn-actualizar" @onclick="@(async () => await RecargarCajaAsync())"><i class="bi bi-arrow-clockwise"></i>Actualizar</button>
                        <button type="button" class="btn-top btn-nuevo" @onclick="NuevoServicioAsync"><i class="bi bi-plus-circle-fill"></i>Nuevo Servicio</button>
                        <button type="button" class="btn-top btn-domicilio" @onclick="DomicilioPendiente"><i class="bi bi-house-door-fill"></i>Domicilio</button>
                        <button type="button" class="btn-top btn-logout" @onclick="EliminarServicioPendiente"><i class="bi bi-trash3-fill"></i>Eliminar servicio</button>
                        <button type="button" class="btn-top btn-ventas" @onclick="VentasPendiente"><i class="bi bi-graph-up-arrow"></i>Ventas</button>
                        <button type="button" class="btn-top btn-domicilio" @onclick="GastosPendiente"><i class="bi bi-wallet2"></i>Gastos</button>
                        <button type="button" class="btn-top btn-cerrar-caja" @onclick="AbrirModalCierreCaja"><i class="bi bi-lock-fill"></i>Cerrar caja</button>
                        <button type="button" class="btn-top btn-logout" @onclick="CerrarSesion"><i class="bi bi-box-arrow-right"></i>Cerrar sesion</button>
                    </div>
                </div>
            </div>

            <div id="bloqueServicios" class="panel panel-alto-auto b-orange mb-1 border-0">
                <div class="row g-1">
                    <div class="col-12 col-lg-12">
                        <div class="box h-cuentas p-1 cuentas-box bg-white">
                            <div class="cuentas-grid">
                                @foreach (var cuenta in Cuentas)
                                {
                                    <button type="button" class="cuenta-card @(cuenta.Activa ? "cuenta-activa" : string.Empty)" @onclick="@(() => SeleccionarCuentaAsync(cuenta.Id))">
                                        <span class="cuenta-edit"><i class="bi bi-pencil-fill"></i></span>
                                        <div class="cuenta-body">
                                            <div class="cuenta-num">@cuenta.Alias</div>
                                            <div class="cuenta-name">@cuenta.Mesa</div>
                                            <div class="cuenta-vendedor" title="@cuenta.Vendedor">@cuenta.Vendedor</div>
                                        </div>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-1 flex-grow-1">
                <div class="col-12 col-lg-5 d-flex">
                    <div id="bloqueZonas" class="panel bg-light w-100 border-1">
                        <div class="row">
                            <div class="col-12 panel-zona">
                                <div class="box p-0 h-zonas zonas-box">
                                    <div class="zonas-grid">
                                        @foreach (var zona in Zonas)
                                        {
                                            <button type="button" class="zona-btn @(zona.Activa ? "zona-activa" : string.Empty)" @onclick="@(() => SeleccionarZona(zona.Id))">@zona.Nombre</button>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="box h-mesas p-1 mesas-box panel-alto-auto">
                                    <div class="mesas-grid panel-alto-auto">
                                        @foreach (var mesa in Mesas)
                                        {
                                            <button type="button"
                                                    class="mesa-btn @(mesa.Ocupada ? "mesa-activa" : string.Empty) @(mesa.Seleccionada ? "mesa-seleccionada" : string.Empty)"
                                                    @onclick="@(() => AbrirMesaAsync(mesa.Id))">
                                                <span class="mesa-titulo">@mesa.Nombre</span>
                                                @if (!string.IsNullOrWhiteSpace(mesa.Vendedor))
                                                {
                                                    <span class="mesa-vendedor">@mesa.Vendedor</span>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-7 d-flex">
                    <div class="panel b-purple w-100">
                        <div class="row g-0">
                            <div id="bloqueBuscarProducto" class="col-12" style="height: 50px">
                                <div class="buscar-wrapper w-100">
                                    <i class="bi bi-search buscar-icon"></i>
                                    <input type="text" class="buscar-input" placeholder="Buscar producto..." autocomplete="off" @bind="BusquedaProducto" @bind:event="oninput" />
                                    <button type="button" class="buscar-clear" @onclick="LimpiarBusquedaProducto"><i class="bi bi-x-lg"></i></button>
                                </div>
                            </div>

                            <div id="bloqueCategorias" class="col-12 panel-alto-auto">
                                <div class="box h-categorias p-1 categorias-box">
                                    <div class="categorias-grid">
                                        @foreach (var categoria in Categorias)
                                        {
                                            <button type="button" class="categoria-btn @(categoria.Activa ? "categoria-activa" : string.Empty)" @onclick="@(() => SeleccionarCategoria(categoria.Id))">@categoria.Nombre</button>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div id="bloqueProductos" class="col-12">
                                <div class="box h-productos p-0 productos-box">
                                    <div class="productos-list">
                                        @foreach (var producto in Productos)
                                        {
                                            <div class="producto-item">
                                                <div class="row g-0 align-items-center">
                                                    <div class="col-12"><div class="producto-nombre">@producto.Nombre</div></div>
                                                    <div class="col-12 col-md-6">
                                                        <div class="producto-sub">
                                                            <span class="producto-precio">@producto.Precio</span>
                                                            <a href="#" class="producto-detalle">Ver detalle</a>
                                                        </div>
                                                    </div>
                                                    <div class="col-12 col-md-6">
                                                        <div class="producto-acciones">
                                                            <button type="button" class="prod-btn prod-minus" @onclick="@(() => CambiarCantidadProducto(producto.Id, -1m))"><i class="bi bi-dash-lg"></i></button>
                                                            <input type="text"
                                                                   class="prod-cant"
                                                                   value="@ObtenerCantidadProducto(producto.Id).ToString("0.##", CultureInfo.InvariantCulture)"
                                                                   inputmode="decimal"
                                                                   @oninput="@((ChangeEventArgs e) => CambiarCantidadProductoInput(producto.Id, e))" />
                                                            <button type="button" class="prod-btn prod-plus" @onclick="@(() => CambiarCantidadProducto(producto.Id, 1m))"><i class="bi bi-plus-lg"></i></button>
                                                            <button type="button" class="prod-btn prod-cart" @onclick="@(() => AgregarProductoAsync(producto.Id))"><i class="bi bi-cart"></i></button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <aside class="col-12 col-xl-4 d-flex">
            <div class="panel w-100">
                <div class="row g-0 h-100 aside-stack">
                    <div id="bloqueResumen" class="col-12">
                        <div class="box h-precios p-0 precios-box">
                            <div class="precios-resumen">
                                <div class="precio-row"><div class="precio-label">SUBTOTAL:</div><div class="precio-value">@ResumenSubtotal</div></div>
                                <div class="precio-row"><div class="precio-label">IMPUESTOS</div><div class="precio-value">@ResumenImpuestos</div></div>
                                <div class="precio-row precio-total"><div class="precio-label">TOTAL 1:</div><div class="precio-value">@ResumenTotal1</div></div>
                                <div class="precio-row precio-servicio">
                                    <div class="precio-label">SERVICIO (@ResumenPorcentajePropina)</div>
                                    <div class="precio-servicio-acciones">
                                        <button type="button" class="btn-servicio-editar" @onclick="AbrirModalPropina">Editar</button>
                                        <div class="precio-value">@ResumenPropina</div>
                                    </div>
                                </div>
                                <div class="precio-row precio-total2"><div class="precio-label">TOTAL 2:</div><div class="precio-value">@ResumenTotal2</div></div>
                            </div>
                            <div class="precios-acciones">
                                <button type="button" class="accion-btn accion-comandar" @onclick="ComandarAsync"><i class="bi bi-send-fill me-1"></i>Comandar</button>
                                <button type="button" class="accion-btn accion-cuenta" @onclick="SolicitarCuentaAsync"><i class="bi bi-chat-square-text-fill me-1"></i>Solicitar<br />Cuenta</button>
                                <button type="button" class="accion-btn accion-cobrar" @onclick="CobrarPendiente"><i class="bi bi-cash-coin me-1"></i>Cobrar</button>
                            </div>
                        </div>
                    </div>

                    <div id="bloqueCuentasDetalle" class="col-12">
                        <div class="box h-nueva-cuenta">
                            <div class="cuentas-header col-12">
                                <button type="button" class="btn-nueva-cuenta" @onclick="AbrirModalNuevaCuenta"><i class="bi bi-plus-lg me-2"></i>Nueva cuenta</button>
                                <button type="button" class="btn-cuenta-general @(SelectedCuentaClienteId == 0 ? "cuenta-item-activa" : string.Empty)" @onclick="@(() => SeleccionarCuentaCliente(0))">
                                    <span>Cuenta General</span>
                                    <span class="cuenta-total">@ResumenTotal2</span>
                                </button>
                            </div>

                            <div class="cuentas-lista">
                                @foreach (var cuentaCliente in CuentasCliente)
                                {
                                    <button type="button" class="cuenta-item @(cuentaCliente.Activa ? "cuenta-item-activa" : string.Empty)" @onclick="@(() => SeleccionarCuentaCliente(cuentaCliente.Id))">
                                        @cuentaCliente.Nombre
                                        <small>@cuentaCliente.Total</small>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <div id="bloqueDetalleProductos" class="col-12">
                        <div class="box h-lista">
                            <div class="row lista-productos">
                                @foreach (var detalle in Detalles)
                                {
                                    <div class="col-6 col-xl-12 item-col">
                                        <div class="producto-item-detalle">
                                            <div class="prod-top-detalle"><div class="prod-nombre">@detalle.Nombre</div><div class="prod-precio">@detalle.Precio</div></div>
                                            <div class="prod-mid-detalle">
                                                <div class="prod-cantidad">
                                                    <button type="button" class="qty-btn" @onclick="@(() => CambiarCantidadDetalle(detalle.Id, -1m))">-</button>
                                                    <input type="text"
                                                           class="qty-input"
                                                           value="@ObtenerCantidadDetalle(detalle.Id).ToString("0.##", CultureInfo.InvariantCulture)"
                                                           inputmode="decimal"
                                                           @oninput="@((ChangeEventArgs e) => CambiarCantidadDetalleInput(detalle.Id, e))" />
                                                    <button type="button" class="qty-btn" @onclick="@(() => CambiarCantidadDetalle(detalle.Id, 1m))">+</button>
                                                </div>
                                                <button type="button" class="save-btn" @onclick="@(() => GuardarCantidadDetalleAsync(detalle.Id))"><i class="bi bi-floppy2-fill"></i></button>
                                            </div>
                                            <div class="prod-actions-detalle">
                                                <button type="button" class="act-btn" @onclick="@(() => AbrirModalNota(detalle.Id))"><i class="bi bi-chat"></i></button>
                                                <button type="button" class="act-btn" @onclick="DetallePendiente"><i class="bi bi-link-45deg"></i></button>
                                                <button type="button" class="act-btn act-danger" @onclick="@(() => EliminarDetalleAsync(detalle.Id))"><i class="bi bi-trash"></i></button>
                                                <button type="button" class="act-btn" @onclick="DetallePendiente"><i class="bi bi-scissors"></i></button>
                                                <button type="button" class="act-btn" @onclick="DetallePendiente"><i class="bi bi-cash-coin"></i></button>
                                                <button type="button" class="act-btn" @onclick="DetallePendiente"><i class="bi bi-pencil-square"></i></button>
                                            </div>
                                            <div class="cuenta-detalle-chip"><i class="bi bi-person-badge"></i><span>@detalle.Cuenta</span></div>
                                            <div class="prod-bottom">
                                                <button type="button" class="nota-btn" @onclick="@(() => AbrirModalNota(detalle.Id))"><i class="bi bi-journal-text me-2"></i><span>@detalle.Nota</span></button>
                                                <div class="prod-total">@detalle.Total</div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</main>

@if (ShowMesaModal)
{
    <div class="modal fade show d-block" tabindex="-1" aria-hidden="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title">Acciones de mesa</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalMesa"></button>
                </div>
                <div class="modal-body">
                    <div class="fw-semibold mb-2">@(MesaSeleccionadaModal?.NombreMesa ?? "Mesa")</div>
                    @if (!string.IsNullOrWhiteSpace(MesaStatusModal))
                    {
                        <div class="alert @(MesaStatusHasError ? "alert-danger" : "alert-success") mb-3">@MesaStatusModal</div>
                    }
                    @if (CuentaMesaModal is null)
                    {
                        <div class="text-muted mb-3">La mesa esta libre. Puedes crear un nuevo servicio y dejarlo relacionado inmediatamente.</div>
                    }
                    else
                    {
                        <div class="text-muted mb-3">Esta mesa ya esta relacionada con el servicio <strong>#@CuentaMesaModal.AliasVenta</strong>.</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CerrarModalMesa" disabled="@IsMesaActionRunning">Cancelar</button>
                    @if (CuentaMesaModal is null)
                    {
                        <button type="button" class="btn btn-primary" @onclick="CrearServicioEnMesaAsync" disabled="@IsMesaActionRunning">Crear servicio</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-primary" @onclick="IrAServicioMesaAsync" disabled="@IsMesaActionRunning">Ir al servicio</button>
                        <button type="button" class="btn btn-danger" @onclick="LiberarMesaAsync" disabled="@IsMesaActionRunning">Liberar mesa</button>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (ShowNuevaCuentaModal)
{
    <div class="modal fade show d-block" tabindex="-1" aria-hidden="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title">Nueva cuenta</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalNuevaCuenta"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Nombre de la cuenta</label>
                    <input type="text" class="form-control" @bind="NuevaCuentaNombre" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CerrarModalNuevaCuenta" disabled="@IsCuentaActionRunning">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="CrearCuentaClienteAsync" disabled="@IsCuentaActionRunning">Crear cuenta</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (ShowNotaModal)
{
    <div class="modal fade show d-block" tabindex="-1" aria-hidden="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title">Nota del producto</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalNota"></button>
                </div>
                <div class="modal-body">
                    @if (NotasRapidas.Any())
                    {
                        <div class="mb-3">
                            <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                                <label class="form-label mb-0">Notas rapidas</label>
                                <button type="button" class="caja-nota-clear" @onclick="LimpiarNotaCompleta">Borrar todo</button>
                            </div>
                            <div class="caja-notas-rapidas">
                                @foreach (var notaRapida in NotasRapidas)
                                {
                                    <button type="button"
                                            class="caja-nota-chip @(NotaRapidaActiva(notaRapida) ? "is-active" : string.Empty)"
                                            @onclick="@(() => ToggleNotaRapida(notaRapida))">
                                        @notaRapida
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-end mb-2">
                            <button type="button" class="caja-nota-clear" @onclick="LimpiarNotaCompleta">Borrar todo</button>
                        </div>
                    }
                    <textarea class="form-control" rows="4" @bind="NotaDetalleTexto"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CerrarModalNota" disabled="@IsDetalleActionRunning">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="GuardarNotaDetalleAsync" disabled="@IsDetalleActionRunning">Guardar nota</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (ShowPropinaModal)
{
    <div class="modal fade show d-block" tabindex="-1" aria-hidden="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title">Editar servicio</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalPropina"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Porcentaje de servicio</label>
                    <input type="text" class="form-control" inputmode="decimal" @bind="PropinaPorcentajeInput" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CerrarModalPropina" disabled="@IsPropinaActionRunning">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="GuardarPropinaAsync" disabled="@IsPropinaActionRunning">Guardar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (ShowCerrarCajaModal)
{
    <div class="modal fade show d-block" tabindex="-1" aria-hidden="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title">Cerrar caja</h5>
                    <button type="button" class="btn-close" @onclick="CancelarCierreCaja"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">Se va a cerrar la base activa <strong>#@BaseCajaIdVisual</strong>.</div>
                    <div class="text-muted small mb-3">Valor base actual: @ValorBaseVisual</div>
                    <div class="mb-3"><label class="form-label">Observacion</label><textarea class="form-control" rows="3" @bind="ObservacionCierre"></textarea></div>
                    @if (!string.IsNullOrWhiteSpace(CajaStatusMessage))
                    {
                        <div class="alert @(CajaStatusHasError ? "alert-danger" : "alert-success") mb-0">@CajaStatusMessage</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelarCierreCaja" disabled="@IsClosingCaja">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmarCierreCajaAsync" disabled="@IsClosingCaja">Confirmar cierre</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (ShowAlertModerno)
{
    <div class="caja-alertmoderno-backdrop" @onclick="CerrarAlertModerno">
        <div class="caja-alertmoderno @(AlertModernoEsError ? "is-error" : "is-success")" @onclick:stopPropagation="true" role="alert" aria-live="assertive">
            <button type="button" class="caja-alertmoderno-close" @onclick="CerrarAlertModerno">
                <i class="bi bi-x-lg"></i>
            </button>
            <div class="caja-alertmoderno-icon">
                <i class="bi @(AlertModernoEsError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i>
            </div>
            <div class="caja-alertmoderno-title">@(AlertModernoEsError ? "Atencion" : "Listo")</div>
            <div class="caja-alertmoderno-text">@AlertModernoMensaje</div>
            <button type="button" class="caja-alertmoderno-accept" @onclick="CerrarAlertModerno">Aceptar</button>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery] private string? Db { get; set; }

    private CajaPageData? CajaData;
    private bool IsLoading = true;
    private string? LoadError;
    private string BusquedaProducto = string.Empty;
    private int SelectedCuentaId;
    private int SelectedZonaId;
    private int SelectedMesaId;
    private int SelectedCategoriaId;
    private int SelectedCuentaClienteId;
    private string LoadingKicker = "Procesando";
    private string LoadingTitle = "Cargando caja";
    private string LoadingCopy = "Estamos consultando la informacion real desde SQL Server.";
    private bool ShowAlertModerno;
    private string AlertModernoMensaje = string.Empty;
    private bool AlertModernoEsError;
    private CancellationTokenSource? AlertModernoCts;

    private bool ShowCerrarCajaModal;
    private bool IsClosingCaja;
    private bool CajaStatusHasError;
    private string ObservacionCierre = string.Empty;
    private string? CajaStatusMessage;

    private readonly Dictionary<int, decimal> ProductoCantidades = [];
    private readonly Dictionary<int, decimal> DetalleCantidades = [];

    private bool ShowMesaModal;
    private bool IsMesaActionRunning;
    private string? MesaStatusModal;
    private bool MesaStatusHasError;
    private MesaCajaData? MesaSeleccionadaModal;
