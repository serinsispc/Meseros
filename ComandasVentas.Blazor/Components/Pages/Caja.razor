    private async Task AgregarProductoAsync(int idPresentacion)
    {
        if (SelectedCuentaId <= 0)
        {
            MostrarMensaje("No hay un servicio activo para agregar productos.", true);
            return;
        }

        var producto = CajaData?.Productos.FirstOrDefault(x => x.IdPresentacion == idPresentacion);
        var cantidad = ObtenerCantidadProducto(idPresentacion);
        if (producto is null || cantidad <= 0)
        {
            MostrarMensaje("No fue posible interpretar el producto a agregar.", true);
            return;
        }

        var resultado = await CajaDataService.AgregarProductoAsync(DbVisual, SelectedCuentaId, idPresentacion, cantidad, SelectedCuentaClienteId);
        if (!resultado.Success)
        {
            MostrarMensaje(resultado.Message, true);
            return;
        }

        ProductoCantidades[idPresentacion] = 1m;
        SelectedCategoriaId = producto.IdCategoria;
        await RecargarCajaAsync(false);
        MostrarMensaje(resultado.Message, false);
    }

