    private async Task GuardarPropinaAsync()
    {
        if (!decimal.TryParse(PropinaPorcentajeInput.Replace(",", "."), NumberStyles.Any, CultureInfo.InvariantCulture, out var porcentaje) || porcentaje < 0)
        {
            MostrarMensaje("Ingresa un porcentaje valido para el servicio.", true);
            return;
        }

        var subtotal = CuentaClienteActual?.SubtotalVenta ?? VentaActual?.SubtotalVenta ?? 0m;
        var propina = Math.Round(subtotal * (porcentaje / 100m), 0, MidpointRounding.AwayFromZero);

        IsPropinaActionRunning = true;
        var resultado = await CajaDataService.EditarPropinaAsync(DbVisual, SelectedCuentaId, SelectedCuentaClienteId, porcentaje, propina);
        IsPropinaActionRunning = false;

        if (!resultado.Success)
        {
            MostrarMensaje(resultado.Message, true);
            return;
        }

        ShowPropinaModal = false;
        await RecargarCajaAsync(false);
        MostrarMensaje(resultado.Message, false);
    }

