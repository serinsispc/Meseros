@using Meseros.Blazor.Models
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Navigation
@inject OperationalContextStore ContextStore

@page "/caja"

<PageTitle>Caja</PageTitle>

<section class="migration-note">
    <h2>Modulo Caja</h2>
    <p>El login Blazor ya entrega el `db` desde la URL y deja el contexto base del usuario autenticado.</p>
    <ul>
        <li>db actual: @_db</li>
        <li>vendedor: @(string.IsNullOrWhiteSpace(ContextStore.VendedorNombre) ? "sin autenticar" : ContextStore.VendedorNombre)</li>
        <li>id base caja: @ContextStore.BaseCajaId</li>
        <li>id usuario caja: @ContextStore.CajaUsuarioId</li>
    </ul>
</section>

@code {
    private string _db = string.Empty;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        _db = query.TryGetValue("db", out var dbValue) ? dbValue.ToString() : ContextStore.Db;
    }
}
